# 放置於 wisp:/opt/grid-master/.env（本檔為範本，實際值不進 git）
SECRET_KEY_BASE=請用 mix phx.gen.secret 生成
PG_PASSWORD=請生成隨機密碼
PHX_HOST=gridmaster.miao-bao.cc
FRONTEND_URL=https://gridmaster.miao-bao.cc
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://gridmaster.miao-bao.cc/auth/discord/callback
# 逗號分隔的 Discord ID 清單，取得 admin 權限（掀桌鍵＋卡面生成工作台）
ADMIN_DISCORD_IDS=
PORT=4000

# 卡面生成圖儲存（Cloudflare R2；admin 工作台用，未設定則落 VM 本地磁碟——磁碟緊，務必設定）
# 金鑰：dash.cloudflare.com → R2 → Manage R2 API Tokens → Object Read & Write，限定 prod bucket
R2_ENDPOINT=https://40026a78307dfb1778ce3146c3e92278.r2.cloudflarestorage.com
R2_BUCKET=grid-master-cards-prod
R2_PUBLIC_BASE=https://pub-654a4928bf344d90b37c429c928986bc.r2.dev
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
